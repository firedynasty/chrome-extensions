{
  "manifest_version": 3,
  "name": "Music Player",
  "version": "2.0",
  "description": "Persistent music player with genre/album playlists",
  "permissions": ["offscreen"],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [{
    "resources": ["playlists.json"],
    "matches": []
  }],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
