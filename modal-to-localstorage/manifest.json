{
  "manifest_version": 3,
  "name": "Quick Notes",
  "version": "1.0",
  "description": "Save and load notes per-site from any page — opens a modal overlay with localStorage persistence",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
