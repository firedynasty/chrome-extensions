{
  "manifest_version": 3,
  "name": "YouTube Links",
  "version": "1.0",
  "description": "Manage YouTube video links on any page — opens a side panel overlay with localStorage persistence",
  "permissions": ["activeTab", "scripting", "storage"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
