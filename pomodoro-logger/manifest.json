{
  "manifest_version": 3,
  "name": "Pomodoro Logger",
  "version": "1.0",
  "description": "Log work/break timestamps to Google Sheets",
  "permissions": ["storage"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
